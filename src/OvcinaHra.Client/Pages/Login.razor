@page "/login"
@inject HttpClient Http
@inject JwtAuthStateProvider AuthProvider
@inject TokenRefreshService RefreshService
@inject NavigationManager Nav

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            @if (Error is not null)
            {
                <div class="alert alert-danger">
                    @(Error switch
                    {
                        "not_registered" => "Nemáš registraci na ovcina.cz. Zaregistruj se nejprve.",
                        "auth_failed" => "Přihlášení se nezdařilo. Zkus to znovu.",
                        "no_email" => "Poskytovatel neposlal emailovou adresu.",
                        "no_token" => "Token nebyl přijat. Zkus to znovu.",
                        _ => $"Chyba: {Error}"
                    })
                </div>
            }

            @* Production: OIDC login via registrace *@
            @if (!string.IsNullOrEmpty(oidcAuthority))
            {
                <div class="card mb-4">
                    <div class="card-header text-center">
                        <h4 class="mb-0">OvčinaHra — Přihlášení</h4>
                    </div>
                    <div class="card-body d-flex flex-column align-items-center">
                        <p class="text-muted mb-3">Přihlásit se pomocí Ovčina účtu</p>
                        <button class="btn btn-primary btn-lg w-100" style="max-width: 320px;" @onclick="LoginOidc" disabled="@loading">
                            @if (loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            <i class="bi bi-shield-lock me-2"></i>Přihlásit přes registrace.ovcina.cz
                        </button>
                    </div>
                </div>
            }

            @* Development: dev-token login *@
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Vývojářský přístup</h5>
                </div>
                <div class="card-body">
                    @if (errorMessage is not null)
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Jméno</label>
                        <input class="form-control" @bind="name" placeholder="Tvoje jméno" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" @bind="email" placeholder="email@ovcina.cz" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="LoginDev" disabled="@loading">
                        @if (loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Přihlásit (dev)
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IConfiguration Config { get; set; } = null!;
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private string? oidcAuthority => Config["OidcAuthority"];
    private string? oidcClientId => Config["OidcClientId"];

    private string name = "Organizátor";
    private string email = "org@ovcina.cz";
    private string? errorMessage;
    private bool loading;

    private void LoginOidc()
    {
        // Redirect to registrace OIDC authorize endpoint
        // The API will handle the code exchange via /api/auth/oidc-callback
        var redirectUri = Uri.EscapeDataString($"{Nav.BaseUri}auth-callback");
        var state = Convert.ToBase64String(Guid.NewGuid().ToByteArray());
        var url = $"{oidcAuthority}/connect/authorize" +
            $"?client_id={oidcClientId}" +
            $"&redirect_uri={redirectUri}" +
            $"&response_type=code" +
            $"&scope=openid+profile+email+roles" +
            $"&state={state}";
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task LoginDev()
    {
        loading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/dev-token",
                new { Name = name, Email = email });

            if (response.IsSuccessStatusCode)
            {
                var token = await response.Content.ReadFromJsonAsync<OvcinaHra.Client.Auth.TokenResponse>();
                if (token is not null)
                {
                    await AuthProvider.SetTokenAsync(token.Token);
                    RefreshService.ScheduleRefresh(token.ExpiresInSeconds);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                errorMessage = "Přihlášení selhalo. Zkuste to znovu.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Chyba: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}
