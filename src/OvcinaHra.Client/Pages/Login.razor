@page "/login"
@inject HttpClient Http
@inject JwtAuthStateProvider AuthProvider
@inject TokenRefreshService RefreshService
@inject NavigationManager Nav

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            @if (Error is not null)
            {
                <div class="alert alert-danger">
                    @(Error switch
                    {
                        "not_registered" => "Nemáš registraci na ovcina.cz. Zaregistruj se nejprve.",
                        "auth_failed" => "Přihlášení se nezdařilo. Zkus to znovu.",
                        "no_email" => "Poskytovatel neposlal emailovou adresu.",
                        "no_token" => "Token nebyl přijat. Zkus to znovu.",
                        _ => $"Chyba: {Error}"
                    })
                </div>
            }

            <div class="card mb-4">
                <div class="card-header text-center">
                    <h4 class="mb-0">OvčinaHra — Přihlášení</h4>
                </div>
                <div class="card-body d-flex flex-column align-items-center">
                    <p class="text-muted mb-3">Přihlásit se pomocí</p>
                    <div class="d-flex flex-column gap-2 w-100" style="max-width: 320px;">
                        <a href="@(apiBaseUrl)/api/auth/login/Google" class="btn btn-outline-dark d-flex align-items-center justify-content-center gap-2 py-2">
                            <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                            Google
                        </a>
                        <a href="@(apiBaseUrl)/api/auth/login/Microsoft" class="btn btn-outline-primary d-flex align-items-center justify-content-center gap-2 py-2">
                            <svg width="18" height="18" viewBox="0 0 21 21"><rect x="1" y="1" width="9" height="9" fill="#f25022"/><rect x="11" y="1" width="9" height="9" fill="#7fba00"/><rect x="1" y="11" width="9" height="9" fill="#00a4ef"/><rect x="11" y="11" width="9" height="9" fill="#ffb900"/></svg>
                            Microsoft
                        </a>
                        <a href="@(apiBaseUrl)/api/auth/login/Seznam" class="btn btn-outline-danger d-flex align-items-center justify-content-center gap-2 py-2">
                            <svg width="18" height="18" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" fill="none" stroke="#cc0000" stroke-width="2"/><text x="12" y="16" text-anchor="middle" font-size="13" font-weight="bold" fill="#cc0000">S</text></svg>
                            Seznam
                        </a>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Vývojářský přístup</h5>
                </div>
                <div class="card-body">
                    @if (errorMessage is not null)
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Jméno</label>
                        <input class="form-control" @bind="name" placeholder="Tvoje jméno" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" @bind="email" placeholder="email@ovcina.cz" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="LoginDev" disabled="@loading">
                        @if (loading) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Přihlásit (dev)
                    </button>

                    <p class="text-muted mt-3 small">
                        Toto je vývojové přihlášení. V produkci bude přesměrování na registrace-ovčina.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IConfiguration Config { get; set; } = null!;
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private string apiBaseUrl => Config["ApiBaseUrl"] ?? "https://localhost:5280";

    private string name = "Organizátor";
    private string email = "org@ovcina.cz";
    private string? errorMessage;
    private bool loading;

    private async Task LoginDev()
    {
        loading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/dev-token",
                new { Name = name, Email = email });

            if (response.IsSuccessStatusCode)
            {
                var token = await response.Content.ReadFromJsonAsync<OvcinaHra.Client.Auth.TokenResponse>();
                if (token is not null)
                {
                    await AuthProvider.SetTokenAsync(token.Token);
                    RefreshService.ScheduleRefresh(token.ExpiresInSeconds);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                errorMessage = "Přihlášení selhalo. Zkuste to znovu.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Chyba: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}
