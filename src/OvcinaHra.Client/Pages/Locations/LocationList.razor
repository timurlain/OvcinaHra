    private List<int> GetLinkedLocationIds(LocationListDto loc)
    {
        var ids = new List<int> { loc.Id };
        if (loc.ParentLocationId.HasValue)
        {
            ids.Add(loc.ParentLocationId.Value);
            ids.AddRange(locations.Where(l => l.ParentLocationId == loc.ParentLocationId && l.Id != loc.Id).Select(l => l.Id));
        }
        else
        {
            ids.AddRange(locations.Where(l => l.ParentLocationId == loc.Id).Select(l => l.Id));
        }
        return ids;
    }

    private static (decimal lat, decimal lon)? TryParseGps(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        input = input.Trim();

        var plainMatch = System.Text.RegularExpressions.Regex.Match(input,
            @"(-?\d{1,3}\.\d+)[,\s]+(-?\d{1,3}\.\d+)");
        if (plainMatch.Success
            && decimal.TryParse(plainMatch.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat1)
            && decimal.TryParse(plainMatch.Groups[2].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lon1)
            && lat1 >= -90 && lat1 <= 90 && lon1 >= -180 && lon1 <= 180)
        {
            return (lat1, lon1);
        }

        var googleMatch = System.Text.RegularExpressions.Regex.Match(input,
            @"[@?/](-?\d{1,3}\.\d+),(-?\d{1,3}\.\d+)");
        if (googleMatch.Success
            && decimal.TryParse(googleMatch.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat2)
            && decimal.TryParse(googleMatch.Groups[2].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lon2)
            && lat2 >= -90 && lat2 <= 90 && lon2 >= -180 && lon2 <= 180)
        {
            return (lat2, lon2);
        }

        var mapyCzMatch = System.Text.RegularExpressions.Regex.Match(input,
            @"[?&]x=(-?\d{1,3}\.\d+).*[?&]y=(-?\d{1,3}\.\d+)");
        if (mapyCzMatch.Success
            && decimal.TryParse(mapyCzMatch.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lonM)
            && decimal.TryParse(mapyCzMatch.Groups[2].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var latM)
            && latM >= -90 && latM <= 90 && lonM >= -180 && lonM <= 180)
        {
            return (latM, lonM);
        }

        var mapyCzNewMatch = System.Text.RegularExpressions.Regex.Match(input,
            @"mapy\.cz/[^?]*?(-?\d{1,3}\.\d+),(-?\d{1,3}\.\d+)");
        if (mapyCzNewMatch.Success
            && decimal.TryParse(mapyCzNewMatch.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat3)
            && decimal.TryParse(mapyCzNewMatch.Groups[2].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lon3)
            && lat3 >= -90 && lat3 <= 90 && lon3 >= -180 && lon3 <= 180)
        {
            return (lat3, lon3);
        }

        var decNsewMatch = System.Text.RegularExpressions.Regex.Match(input,
            @"(\d{1,3}\.\d+)\s*([NSns])[,\s]+(\d{1,3}\.\d+)\s*([EWew])");
        if (decNsewMatch.Success
            && decimal.TryParse(decNsewMatch.Groups[1].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var latN)
            && decimal.TryParse(decNsewMatch.Groups[3].Value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lonN))
        {
            if (decNsewMatch.Groups[2].Value.ToUpperInvariant() == "S") latN = -latN;
            if (decNsewMatch.Groups[4].Value.ToUpperInvariant() == "W") lonN = -lonN;
            if (latN >= -90 && latN <= 90 && lonN >= -180 && lonN <= 180)
                return (latN, lonN);
        }

        var dmsMatch = System.Text.RegularExpressions.Regex.Match(input,
            @"(\d{1,3})°(\d{1,2})'([\d.]+)""?\s*([NSns])\s*(\d{1,3})°(\d{1,2})'([\d.]+)""?\s*([EWew])");
        if (dmsMatch.Success)
        {
            static decimal DmsToDecimal(string d, string m, string s, string dir)
            {
                var dec = decimal.Parse(d, System.Globalization.CultureInfo.InvariantCulture)
                    + decimal.Parse(m, System.Globalization.CultureInfo.InvariantCulture) / 60m
                    + decimal.Parse(s, System.Globalization.CultureInfo.InvariantCulture) / 3600m;
                return dir.ToUpperInvariant() is "S" or "W" ? -dec : dec;
            }
            var latD = DmsToDecimal(dmsMatch.Groups[1].Value, dmsMatch.Groups[2].Value, dmsMatch.Groups[3].Value, dmsMatch.Groups[4].Value);
            var lonD = DmsToDecimal(dmsMatch.Groups[5].Value, dmsMatch.Groups[6].Value, dmsMatch.Groups[7].Value, dmsMatch.Groups[8].Value);
            if (latD >= -90 && latD <= 90 && lonD >= -180 && lonD <= 180)
                return (latD, lonD);
        }

        return null;
    }

    private async Task ApplyGpsAsync()
    {
        if (gpsParsed is null || gpsTarget is null) return;
        gpsError = null;
        isSaving = true;
        try
        {
            var ids = GetLinkedLocationIds(gpsTarget);
            foreach (var id in ids)
            {
                var detail = await Api.GetAsync<LocationDetailDto>($"/api/locations/{id}");
                if (detail is null) continue;
                await Api.PutAsync($"/api/locations/{id}",
                    new UpdateLocationDto(detail.Name, detail.LocationKind,
                        gpsParsed.Value.lat, gpsParsed.Value.lon,
                        detail.Description,
                        Details: detail.Details, GamePotential: detail.GamePotential, Region: detail.Region,
                        NpcInfo: detail.NpcInfo, SetupNotes: detail.SetupNotes));
            }
            isGpsVisible = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { gpsError = ex.Message; }
        finally { isSaving = false; }
    }

    // --- Link (propojit) dialog ---
    private void OpenLinkDialog(LocationListDto loc)
    {
        linkTarget = loc;
        linkParentId = loc.ParentLocationId;
        linkError = null;
        linkCandidates = locations
            .Where(l => l.Id != loc.Id && l.ParentLocationId != loc.Id)
            .OrderBy(l => l.Name)
            .ToList();
        isLinkVisible = true;
    }

    private async Task ApplyLinkAsync()
    {
        if (linkTarget is null || linkParentId is null) return;
        linkError = null;
        isSaving = true;
        try
        {
            var detail = await Api.GetAsync<LocationDetailDto>($"/api/locations/{linkTarget.Id}");
            if (detail is null) return;
            await Api.PutAsync($"/api/locations/{linkTarget.Id}",
                new UpdateLocationDto(detail.Name, detail.LocationKind,
                    detail.Latitude, detail.Longitude,
                    detail.Description,
                    Details: detail.Details, GamePotential: detail.GamePotential, Region: detail.Region,
                    NpcInfo: detail.NpcInfo, SetupNotes: detail.SetupNotes,
                    ParentLocationId: linkParentId));
            isLinkVisible = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { linkError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task UnlinkAsync()
    {
        if (linkTarget is null) return;
        linkError = null;
        isSaving = true;
        try
        {
            var detail = await Api.GetAsync<LocationDetailDto>($"/api/locations/{linkTarget.Id}");
