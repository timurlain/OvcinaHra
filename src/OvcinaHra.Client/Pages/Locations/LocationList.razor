@page "/lokace"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<h1>Lokace</h1>

<div class="mb-3">
    <button class="btn btn-primary" data-testid="create-location" @onclick="GoToCreate">
        + Nová lokace
    </button>
</div>

@if (loading)
{
    <p>Načítám...</p>
}
else if (locations.Count == 0)
{
    <p class="text-muted">Žádné lokace.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Název</th>
                <th>Typ</th>
                <th>Zeměpisná šířka</th>
                <th>Zeměpisná délka</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loc in locations)
            {
                <tr data-testid="location-row">
                    <td>@loc.Name</td>
                    <td>@loc.LocationKind.GetDisplayName()</td>
                    <td>@loc.Latitude.ToString("F5")</td>
                    <td>@loc.Longitude.ToString("F5")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => GoToEdit(loc.Id)">
                            Upravit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<LocationListDto> locations = [];
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        locations = await Api.GetListAsync<LocationListDto>("/api/locations");
        loading = false;
    }

    private void GoToCreate() => Nav.NavigateTo("/lokace/nova");
    private void GoToEdit(int id) => Nav.NavigateTo($"/lokace/{id}");
}
