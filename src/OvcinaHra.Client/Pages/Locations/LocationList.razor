    };

    private static string PluralCz(int n, string one, string few, string many)
    {
        if (n == 1) return one;
        if (n >= 2 && n <= 4) return few;
        return many;
    }

    // --- GPS dialog ---
    private void OpenGpsDialog(LocationListDto loc)
