@page "/mapa"
@attribute [Authorize]
@inject ApiClient Api
@inject GameContextService GameContext
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="mb-0">Mapa</h1>
    <div class="d-flex gap-2 align-items-center">
        <div class="btn-group btn-group-sm">
            <button class="btn @(useVector ? "btn-outline-secondary" : "btn-secondary")" @onclick="() => ToggleStyle(false)">Turistická</button>
            <button class="btn @(useVector ? "btn-secondary" : "btn-outline-secondary")" @onclick="() => ToggleStyle(true)">Vektorová</button>
        </div>
        @if (placingMode)
        {
            <span class="badge bg-warning text-dark">Klikni na mapu pro umístění</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelPlacing">Zrušit</button>
        }
        else
        {
            <button class="btn btn-primary btn-sm" @onclick="StartPlacing">+ Nová lokace (klikni na mapu)</button>
        }
    </div>
</div>

<MapView @ref="mapView"
         CenterLat="49.4532461" CenterLon="18.0203242" Zoom="16"
         OnMapClick="HandleMapClick"
         OnMarkerClick="HandleMarkerClick" />

@* Location detail popup *@
<DxPopup AllowResize="true" @bind-Visible="@isModalVisible" HeaderText="@modalTitle" Width="550px">
    <BodyContentTemplate Context="popupContext">
        <DxFormLayout>
            <DxFormLayoutItem Caption="Název" ColSpanMd="12">
                <DxTextBox @bind-Text="@locName" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Typ" ColSpanMd="12">
                <DxComboBox Data="@kindValues" @bind-Value="@locKind" TextFieldName="Display" ValueFieldName="Value" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Šířka" ColSpanMd="6">
                <DxSpinEdit @bind-Value="@locLat" Increment="0.00001m" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Délka" ColSpanMd="6">
                <DxSpinEdit @bind-Value="@locLon" Increment="0.00001m" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Popis" ColSpanMd="12">
                <DxMemo @bind-Text="@locDescription" Rows="2" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Info pro CP" ColSpanMd="12">
                <DxMemo @bind-Text="@locNpcInfo" Rows="2" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Co nachystat" ColSpanMd="12">
                <DxMemo @bind-Text="@locSetupNotes" Rows="2" />
            </DxFormLayoutItem>
        </DxFormLayout>

        @if (error is not null) { <div class="alert alert-danger mt-2">@error</div> }

        <div class="d-flex gap-2 mt-3">
            @if (editingId.HasValue)
            {
                <button class="btn btn-outline-danger" @onclick="() => isDeleteVisible = true">Smazat</button>
            }
            <div style="flex: 1"></div>
            <button class="btn btn-secondary" @onclick="() => isModalVisible = false" disabled="@isSaving">Zrušit</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">Uložit</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@isDeleteVisible" HeaderText="Potvrdit smazání" Width="400px">
    <BodyContentTemplate Context="popupContext">
        <p>Smazat lokaci <strong>@locName</strong>?</p>
        <div class="d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isDeleteVisible = false">Zrušit</button>
            <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Smazat</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    private MapView mapView = null!;
    private List<LocationListDto> locations = [];
    private bool placingMode, isModalVisible, isDeleteVisible, isSaving, useVector;
    private string modalTitle = "", locName = "";
    private string? error, locDescription, locNpcInfo, locSetupNotes;
    private int? editingId;
    private LocationKind locKind = LocationKind.Village;
    private decimal locLat = 49.75m, locLon = 17.25m;

    private static readonly Dictionary<LocationKind, string> markerColors = new()
    {
        [LocationKind.Town] = "#2c3e50",
        [LocationKind.Village] = "#27ae60",
        [LocationKind.Magical] = "#8e44ad",
        [LocationKind.Hobbit] = "#f39c12",
        [LocationKind.Wilderness] = "#16a085",
        [LocationKind.Dungeon] = "#c0392b",
        [LocationKind.PointOfInterest] = "#2980b9"
    };

    private static readonly List<KindItem> kindValues = Enum.GetValues<LocationKind>()
        .Select(k => new KindItem(k, k.GetDisplayName())).ToList();
    record KindItem(LocationKind Value, string Display);

    protected override async Task OnInitializedAsync()
    {
        await GameContext.InitializeAsync();
        GameContext.OnGameChanged += OnGameChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadAndDisplayLocationsAsync();
            // Fit to game area bounds
            await mapView.FitBoundsAsync(49.4504644, 18.0177633, 49.4557139, 18.0229133);
        }
    }

    private async Task ToggleStyle(bool vector)
    {
        useVector = vector;
        await mapView.SwitchStyleAsync(vector);
        await LoadAndDisplayLocationsAsync();
    }

    private async void OnGameChanged() { await LoadAndDisplayLocationsAsync(); StateHasChanged(); }
    public void Dispose() => GameContext.OnGameChanged -= OnGameChanged;

    private async Task LoadAndDisplayLocationsAsync()
    {
        locations = await Api.GetListAsync<LocationListDto>("/api/locations");
        await mapView.ClearMarkersAsync();
        foreach (var loc in locations)
        {
            var color = markerColors.GetValueOrDefault(loc.LocationKind, "#e74c3c");
            await mapView.AddMarkerAsync(loc.Id, (double)loc.Latitude, (double)loc.Longitude,
                loc.Name, loc.LocationKind.GetDisplayName(), color);
        }
    }

    private void StartPlacing() => placingMode = true;
    private void CancelPlacing() => placingMode = false;

    private async Task HandleMapClick(OvcinaMapClickEventArgs e)
    {
        if (placingMode)
        {
            placingMode = false;
            editingId = null;
            locName = "";
            locKind = LocationKind.Village;
            locLat = (decimal)e.Latitude;
            locLon = (decimal)e.Longitude;
            locDescription = null; locNpcInfo = null; locSetupNotes = null;
            error = null;
            modalTitle = "Nová lokace";
            isModalVisible = true;
            StateHasChanged();
        }
    }

    private async Task HandleMarkerClick(int id)
    {
        var loc = locations.FirstOrDefault(l => l.Id == id);
        if (loc is null) return;

        editingId = id;
        locName = loc.Name;
        locKind = loc.LocationKind;
        locLat = loc.Latitude;
        locLon = loc.Longitude;
        error = null;
        modalTitle = $"Upravit: {loc.Name}";

        // Load full detail
        var detail = await Api.GetAsync<LocationDetailDto>($"/api/locations/{id}");
        if (detail is not null)
        {
            locDescription = detail.Description;
            locNpcInfo = detail.NpcInfo;
            locSetupNotes = detail.SetupNotes;
        }

        isModalVisible = true;
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        error = null; isSaving = true;
        try
        {
            if (editingId.HasValue)
            {
                await Api.PutAsync($"/api/locations/{editingId}",
                    new UpdateLocationDto(locName, locKind, locLat, locLon, locDescription, locNpcInfo, locSetupNotes));
            }
            else
            {
                await Api.PostAsync<CreateLocationDto, LocationDetailDto>("/api/locations",
                    new CreateLocationDto(locName, locKind, locLat, locLon, locDescription, locNpcInfo, locSetupNotes));
            }
            isModalVisible = false;
            await LoadAndDisplayLocationsAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            await Api.DeleteAsync($"/api/locations/{editingId}");
            isDeleteVisible = false; isModalVisible = false;
            await LoadAndDisplayLocationsAsync();
        }
        catch (Exception ex) { error = ex.Message; }
    }
}
