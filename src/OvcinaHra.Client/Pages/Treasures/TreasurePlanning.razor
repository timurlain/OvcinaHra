        if (selectedPool.Count == 1)
        {
            await QuickAssignPoolItemAsync(selectedPool[0], locationId, "click-fallback");
            return;
        }

        focusTab = selectedPool.Count > 0 ? "pridat" : "prehled";
        StateHasChanged();
    }

