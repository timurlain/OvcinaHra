@page "/poklady"
@attribute [Authorize]
@inject ApiClient Api

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Poklady</h1>
    <button class="btn btn-primary" @onclick="() => OpenModal(null)">+ Nový poklad</button>
</div>

@if (loading) { <p>Načítám...</p> }
else
{
    <OvcinaGrid Data="@treasures" KeyFieldName="Id" LayoutKey="grid-layout-treasures"
                RowClick="@(e => OpenModal((TreasureQuestListDto)e.Grid.GetDataItem(e.VisibleIndex)))">
        <Columns>
            <DxGridDataColumn FieldName="Title" Caption="Název" />
            <DxGridDataColumn FieldName="Difficulty" Caption="Obtížnost" Width="130px">
                <CellDisplayTemplate>@(((TreasureQuestDifficulty)context.Value).GetDisplayName())</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="LocationId" Caption="Lokace ID" Width="100px" />
            <DxGridDataColumn FieldName="SecretStashId" Caption="Skrýš ID" Width="100px" />
            <DxGridDataColumn FieldName="GameId" Caption="Hra ID" Width="80px" Visible="false" />
        </Columns>
    </OvcinaGrid>
}

<DxPopup AllowResize="true" @bind-Visible="@isModalVisible" HeaderText="@modalTitle" Width="550px">
    <BodyContentTemplate Context="popupContext">
        <DxFormLayout>
            <DxFormLayoutItem Caption="Název" ColSpanMd="12">
                <DxTextBox @bind-Text="@title" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Obtížnost" ColSpanMd="6">
                <DxComboBox Data="@difficultyValues" @bind-Value="@difficulty" TextFieldName="Display" ValueFieldName="Value" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Hra ID" ColSpanMd="6">
                <DxSpinEdit @bind-Value="@gameId" MinValue="1" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Nápověda" ColSpanMd="12">
                <DxMemo @bind-Text="@clue" Rows="2" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Lokace ID (nebo skrýš)" ColSpanMd="6">
                <DxSpinEdit @bind-Value="@locationId" MinValue="0" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Skrýš ID (nebo lokace)" ColSpanMd="6">
                <DxSpinEdit @bind-Value="@secretStashId" MinValue="0" />
            </DxFormLayoutItem>
        </DxFormLayout>
        @if (error is not null) { <div class="alert alert-danger mt-2">@error</div> }
        <div class="d-flex gap-2 mt-3">
            @if (editingId.HasValue) { <button class="btn btn-outline-danger" @onclick="() => isDeleteVisible = true">Smazat</button> }
            <div style="flex: 1"></div>
            <button class="btn btn-secondary" @onclick="() => isModalVisible = false">Zrušit</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">Uložit</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@isDeleteVisible" HeaderText="Potvrdit smazání" Width="400px">
    <BodyContentTemplate Context="popupContext">
        <p>Smazat poklad <strong>@title</strong>?</p>
        <div class="d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isDeleteVisible = false">Zrušit</button>
            <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Smazat</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    private List<TreasureQuestListDto> treasures = []; private bool loading = true, isModalVisible, isDeleteVisible, isSaving;
    private string modalTitle = "", title = ""; private string? error, clue; private int? editingId;
    private TreasureQuestDifficulty difficulty = TreasureQuestDifficulty.Start;
    private int gameId = 1, locationId, secretStashId;

    private static readonly List<EnumItem<TreasureQuestDifficulty>> difficultyValues = Enum.GetValues<TreasureQuestDifficulty>()
        .Select(v => new EnumItem<TreasureQuestDifficulty>(v, v.GetDisplayName())).ToList();
    record EnumItem<T>(T Value, string Display);

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() { loading = true; treasures = await Api.GetListAsync<TreasureQuestListDto>("/api/treasure-quests/by-game/1"); loading = false; }

    private void OpenModal(TreasureQuestListDto? t)
    {
        error = null;
        if (t is null) { editingId = null; title = ""; clue = null; difficulty = TreasureQuestDifficulty.Start; gameId = 1; locationId = 0; secretStashId = 0; modalTitle = "Nový poklad"; }
        else { editingId = t.Id; title = t.Title; difficulty = t.Difficulty; gameId = t.GameId; locationId = t.LocationId ?? 0; secretStashId = t.SecretStashId ?? 0; modalTitle = $"Upravit: {t.Title}"; _ = LoadDetailAsync(t.Id); }
        isModalVisible = true;
    }

    private async Task LoadDetailAsync(int id)
    {
        var d = await Api.GetAsync<TreasureQuestDetailDto>($"/api/treasure-quests/{id}");
        if (d is not null) { clue = d.Clue; StateHasChanged(); }
    }

    private async Task SaveAsync()
    {
        error = null; isSaving = true;
        try
        {
            int? locId = locationId > 0 ? locationId : null; int? stashId = secretStashId > 0 ? secretStashId : null;
            if (editingId.HasValue)
                await Api.PutAsync($"/api/treasure-quests/{editingId}", new UpdateTreasureQuestDto(title, clue, difficulty, locId, stashId));
            else
                await Api.PostAsync<CreateTreasureQuestDto, TreasureQuestListDto>("/api/treasure-quests", new CreateTreasureQuestDto(title, difficulty, gameId, clue, locId, stashId));
            isModalVisible = false; await LoadAsync();
        }
        catch (Exception ex) { error = ex.Message; } finally { isSaving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        try { await Api.DeleteAsync($"/api/treasure-quests/{editingId}"); isDeleteVisible = false; isModalVisible = false; await LoadAsync(); }
        catch (Exception ex) { error = ex.Message; }
    }
}
