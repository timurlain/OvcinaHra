@page "/hry/{Id:int}"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<h1>Upravit hru</h1>

@if (loading)
{
    <p>Načítám...</p>
}
else if (game is null)
{
    <p class="text-danger">Hra nenalezena.</p>
}
else
{
    <GameForm Model="model" OnSave="Save" OnCancel="Cancel" IsEdit="true" OnDelete="Delete" />
}

@code {
    [Parameter] public int Id { get; set; }

    private GameDetailDto? game;
    private GameFormModel model = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        game = await Api.GetAsync<GameDetailDto>($"/api/games/{Id}");
        if (game is not null)
            model = GameFormModel.FromDetail(game);
        loading = false;
    }

    private async Task Save()
    {
        await Api.PutAsync($"/api/games/{Id}", model.ToUpdateDto());
        Nav.NavigateTo("/hry");
    }

    private async Task Delete()
    {
        await Api.DeleteAsync($"/api/games/{Id}");
        Nav.NavigateTo("/hry");
    }

    private void Cancel() => Nav.NavigateTo("/hry");
}
