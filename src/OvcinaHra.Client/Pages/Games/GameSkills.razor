@page "/games/{GameId:int}/skills"
@attribute [Authorize]
@inject SkillService SkillSvc
@inject ApiClient Api
@inject NavigationManager Nav

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Dovednosti hry</h1>
    <div class="d-flex gap-2">
        @* Two named actions per #153 designer note "Šablona ↔ kopie": each
           GameSkill is an independent fork — making the source explicit at
           create-time helps organizers think about it that way. The original
           combined chooser popup remains reachable for backwards-compat but
           the entry points lead straight to the right step. *@
        <button class="btn btn-primary" type="button" @onclick="OpenFromTemplateStep"
                title="Vytvořit kopii z existující šablony">
            <i class="bi bi-stack"></i> Přidat ze šablony
        </button>
        <button class="btn btn-outline-primary" type="button" @onclick="OpenCustomEdit"
                title="Vytvořit dovednost úplně od nuly">
            <i class="bi bi-plus-square"></i> Od nuly
        </button>
        <button class="btn btn-outline-secondary" type="button"
                @onclick="@(() => Nav.NavigateTo("/games"))">
            <i class="bi bi-arrow-left"></i> Zpět na hry
        </button>
    </div>
</div>

@if (loading)
{
    <p>Načítám...</p>
}
else
{
    @if (gameSkills.Count == 0)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-star fs-1 d-block mb-2"></i>
            <p>Tato hra zatím nemá žádné dovednosti. Přidejte první pomocí tlačítka nahoře.</p>
        </div>
    }
    else
    {
        @* LayoutKey bumped grid-layout-game-skills → -v2 because the column
           schema changed (new source / drift / chip / pip cells, renamed
           Povolání → Třída). Memory rule: feedback_ovcinagrid_layoutkey_bump. *@
        <OvcinaGrid Data="@gameSkills" KeyFieldName="Id" LayoutKey="grid-layout-game-skills-v2"
                    RowClick="@(e => OpenEditPopup((GameSkillDto)e.Grid.GetDataItem(e.VisibleIndex)))">
            <Columns>
                @* Source badge — Šablona #N when copied from a template, Od nuly when blank *@
                <DxGridDataColumn FieldName="TemplateSkillId" Caption="Zdroj" Width="120px">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        @if (row.TemplateSkillId is int tid)
                        {
                            <span class="oh-sk-src-badge oh-sk-src-badge--tpl" title="@($"Vytvořeno ze šablony #{tid}")">Šablona #@tid</span>
                        }
                        else
                        {
                            <span class="oh-sk-src-badge oh-sk-src-badge--blank" title="Vytvořeno od nuly">Od nuly</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                @* Drift glyph — visible only when per-game fields diverge from the template.
                   Detection is client-side per the design brief. *@
                <DxGridDataColumn Caption="≠" Width="48px" AllowSort="false" AllowGroup="false">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        @if (HasDrift(row))
                        {
                            <span class="oh-sk-drift" title="Pole se liší od šablony">≠</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="Name" Caption="Název" MinWidth="180" />

                <DxGridDataColumn FieldName="Category" Caption="Kategorie" Width="150px">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        <SkillCategoryChip Category="@row.Category" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="ClassRestriction" Caption="Třída" Width="120px">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        <ClassPip Class="@row.ClassRestriction" ShowAllLine="false" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="BuildingRequirementIds" Caption="Budovy" Width="220px"
                                  AllowSort="false" AllowGroup="false">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        <SkillBuildingChips BuildingIds="@row.BuildingRequirementIds" Names="@buildingNames" MaxVisible="3" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="XpCost" Caption="XP" Width="80px">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        <span class="oh-sk-xp @(row.XpCost == 0 ? "oh-sk-xp--zero" : "")" title="@($"Cena: {row.XpCost} XP")">@row.XpCost XP</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="LevelRequirement" Caption="Úroveň" Width="100px">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; var lvl = row.LevelRequirement; }
                        @if (lvl.HasValue)
                        {
                            <span class="oh-sk-lvl" title="Min. úroveň postavy">Lv. @lvl.Value</span>
                        }
                        else
                        {
                            <span class="text-muted small">—</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="Effect" Caption="Efekt" MinWidth="240" Visible="false">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        <span class="oh-sk-c-fx" title="@row.Effect">@(row.Effect ?? "")</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn Caption="" Width="60px" AllowSort="false" AllowGroup="false">
                    <CellDisplayTemplate>
                        @{ var row = (GameSkillDto)context.DataItem; }
                        <button class="btn btn-sm btn-outline-danger" type="button"
                                title="Smazat"
                                @onclick="() => OpenDeletePopup(row)"
                                @onclick:stopPropagation="true">
                            <i class="bi bi-x"></i>
                        </button>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </OvcinaGrid>
    }
}

@* Chooser popup — "Ze šablony" vs "Vlastní" *@
<DxPopup @bind-Visible="@isChooserVisible" HeaderText="Přidat dovednost" Width="480px">
    <BodyContentTemplate Context="popupContext">
        <p class="text-muted small mb-3">
            Vyberte, zda chcete přidat dovednost podle existující šablony z knihovny, nebo zcela vlastní.
        </p>
        <div class="d-flex gap-2 justify-content-center">
            <button class="btn btn-primary" @onclick="OpenFromTemplateStep">
                <i class="bi bi-collection"></i> Ze šablony
            </button>
            <button class="btn btn-outline-primary" @onclick="OpenCustomEdit">
                <i class="bi bi-plus-square"></i> Vlastní
            </button>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isChooserVisible = false">Zrušit</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@* Template picker popup *@
<DxPopup @bind-Visible="@isTemplatePickerVisible" HeaderText="Vybrat šablonu" Width="520px">
    <BodyContentTemplate Context="popupContext">
        @if (AvailableTemplates.Count == 0)
        {
            <div class="alert alert-warning small">
                V knihovně nejsou žádné další šablony, které by tato hra neměla.
            </div>
        }
        else
        {
            <label class="form-label">Šablona</label>
            <DxComboBox Data="@AvailableTemplates"
                        @bind-Value="@pickedTemplateId"
                        TextFieldName="Display"
                        ValueFieldName="Id"
                        NullText="(vyberte šablonu)"
                        SearchMode="ListSearchMode.AutoSearch" />
        }
        <div class="d-flex gap-2 mt-3 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isTemplatePickerVisible = false">Zrušit</button>
            <button class="btn btn-primary"
                    disabled="@(pickedTemplateId is null)"
                    @onclick="OpenEditFromTemplate">
                Pokračovat
            </button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@* Edit popup — full editable form for a GameSkill *@
<DxPopup AllowResize="true" @bind-Visible="@isEditVisible" HeaderText="@editTitle" Width="680px">
    <BodyContentTemplate Context="popupContext">
        @if (editError is not null)
        {
            <div class="alert alert-danger">@editError</div>
        }

        <div class="mb-2 small text-muted">
            @templateInfoLine
        </div>

        <DxFormLayout>
            <DxFormLayoutItem Caption="Název" ColSpanMd="12">
                <DxTextBox @bind-Text="@editName" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Kategorie" ColSpanMd="12">
                <DxComboBox Data="@skillCategoryValues" @bind-Value="@editCategory"
                            TextFieldName="Display" ValueFieldName="Value" />
            </DxFormLayoutItem>

            @if (editCategory == SkillCategory.Class)
            {
                <DxFormLayoutItem Caption="Povolání" ColSpanMd="12">
                    <DxComboBox Data="@playerClassValues" @bind-Value="@editClassRestriction"
                                TextFieldName="Display" ValueFieldName="Value" />
                </DxFormLayoutItem>
            }

            <DxFormLayoutItem Caption="Efekt" ColSpanMd="12">
                <DxMemo @bind-Text="@editEffect" Rows="3" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Poznámka k požadavkům" ColSpanMd="12">
                <DxMemo @bind-Text="@editRequirementNotes" Rows="2" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Požadované budovy" ColSpanMd="12">
                <div>
                    @if (editBuildingIds.Count > 0)
                    {
                        <ul class="list-unstyled mb-2">
                            @foreach (var id in editBuildingIds)
                            {
                                <li class="d-inline-block me-2 mb-1">
                                    <span class="badge bg-secondary">
                                        @(buildingNames.TryGetValue(id, out var n) ? n : $"#{id}")
                                        <button type="button" class="btn btn-sm btn-link text-white p-0 ms-1"
                                                @onclick="() => RemoveBuilding(id)" title="Odebrat">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small mb-2">Žádné požadované budovy.</p>
                    }
                    <div class="d-flex gap-2 align-items-end">
                        <div style="flex:1">
                            <DxComboBox Data="@AvailableBuildings" @bind-Value="@newBuildingId"
                                        TextFieldName="Name" ValueFieldName="Id"
                                        NullText="(přidat budovu)" SearchMode="ListSearchMode.AutoSearch" />
                        </div>
                        <button class="btn btn-sm btn-outline-primary" style="height:34px"
                                disabled="@(newBuildingId is null)" @onclick="AddBuilding">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                </div>
            </DxFormLayoutItem>

            @* Per-game-only fork fields — XpCost + LevelRequirement do not
               exist on the catalog Skill template; they live on this fork
               only. The banner makes that explicit per the #153 brief
               ("Tato úprava ovlivní jen tuto hru, ne šablonu" hint). *@
            <DxFormLayoutItem ColSpanMd="12">
                <div class="oh-sk-pg-only">
                    <div class="oh-sk-pg-only-head"><i class="bi bi-controller"></i> Pouze v této hře</div>
                    <p class="oh-sk-pg-fork-hint">Cena v XP a požadovaná úroveň jsou per-hru — neuloží se zpět do šablony.</p>
                </div>
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Cena v XP" ColSpanMd="12">
                <DxSpinEdit @bind-Value="@xpCost" MinValue="0" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Požadovaná úroveň" ColSpanMd="12">
                <div class="d-flex gap-3 align-items-center">
                    <label class="form-check-label">
                        <input type="checkbox" class="form-check-input me-1"
                               checked="@(!levelRequirement.HasValue)"
                               @onchange="OnNoLevelRequirementChanged" />
                        Bez požadavku
                    </label>
                    @if (levelRequirement.HasValue)
                    {
                        <div style="flex:1; max-width:200px">
                            <DxSpinEdit TValue="int" Value="@levelRequirement.Value"
                                        ValueChanged="@((int v) => levelRequirement = v)"
                                        MinValue="0" />
                        </div>
                    }
                </div>
            </DxFormLayoutItem>
        </DxFormLayout>

        <div class="d-flex gap-2 mt-3">
            <div style="flex: 1"></div>
            <button class="btn btn-secondary" @onclick="() => isEditVisible = false" disabled="@isSaving">Zrušit</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Uložit
            </button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@* Delete confirmation popup *@
<DxPopup @bind-Visible="@isDeleteVisible" HeaderText="Potvrdit odebrání" Width="450px">
    <BodyContentTemplate Context="popupContext">
        @if (deleteError is not null)
        {
            <div class="alert alert-danger">@deleteError</div>
        }
        <p>Opravdu odebrat dovednost <strong>@deletingSkillName</strong> z této hry?</p>
        <div class="d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isDeleteVisible = false" disabled="@isDeleting">Ne</button>
            <button class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@isDeleting">
                @if (isDeleting)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Ano, odebrat
            </button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    [Parameter] public int GameId { get; set; }


    private bool loading = true;
    private List<GameSkillDto> gameSkills = [];
    private List<SkillDto> allTemplates = [];
    private List<BuildingListDto> allBuildings = [];
    private Dictionary<int, string> buildingNames = [];

    // Chooser popup
    private bool isChooserVisible;

    // Template picker popup
    private bool isTemplatePickerVisible;
    private int? pickedTemplateId;

    // Edit popup state (for both create-from-template, create-custom, and update)
    private bool isEditVisible;
    private bool isSaving;
    private string editTitle = "";
    private string? editError;
    private int? editingGameSkillId;   // null => create; set => update
    private int? editingTemplateSkillId; // passed along on create; unchanged on update
    private string templateInfoLine = "";
    private string editName = "";
    private SkillCategory editCategory = SkillCategory.Class;
    private PlayerClass editClassRestriction = PlayerClass.Warrior;
    private string? editEffect;
    private string? editRequirementNotes;
    private List<int> editBuildingIds = [];
    private int? newBuildingId;
    private int xpCost;
    private int? levelRequirement;

    // Delete popup state
    private bool isDeleteVisible;
    private bool isDeleting;
    private int deletingGameSkillId;
    private string deletingSkillName = "";
    private string? deleteError;

    private static readonly List<EnumItem<PlayerClass>> playerClassValues = Enum.GetValues<PlayerClass>()
        .Select(v => new EnumItem<PlayerClass>(v, v.GetDisplayName())).ToList();

    private static readonly List<EnumItem<SkillCategory>> skillCategoryValues = Enum.GetValues<SkillCategory>()
        .Select(v => new EnumItem<SkillCategory>(v, v.GetDisplayName())).ToList();

    private record EnumItem<T>(T Value, string Display);

    private record TemplateOption(int Id, string Name, string Display);

    private List<TemplateOption> AvailableTemplates
    {
        get
        {
            var usedTemplateIds = gameSkills
                .Where(gs => gs.TemplateSkillId.HasValue)
                .Select(gs => gs.TemplateSkillId!.Value)
                .ToHashSet();
            return allTemplates
                .Where(t => !usedTemplateIds.Contains(t.Id))
                .Select(t => new TemplateOption(
                    t.Id,
                    t.Name,
                    $"{t.Name} ({t.ClassRestriction.GetClassRestrictionLabel()})"))
                .ToList();
        }
    }

    private IEnumerable<BuildingListDto> AvailableBuildings
        => allBuildings.Where(b => !editBuildingIds.Contains(b.Id));

    /// <summary>
    /// True when any per-game field on the GameSkill diverges from its
    /// template Skill. Per-game-only fields (XpCost, LevelRequirement) are
    /// excluded — they're expected to vary by design. Detection happens
    /// client-side per the #153 brief — no server roundtrip needed.
    /// </summary>
    private bool HasDrift(GameSkillDto gs)
    {
        if (!gs.TemplateSkillId.HasValue) return false;
        var template = allTemplates.FirstOrDefault(t => t.Id == gs.TemplateSkillId.Value);
        if (template is null) return false;
        if (!string.Equals(gs.Name, template.Name, StringComparison.Ordinal)) return true;
        if (gs.Category != template.Category) return true;
        if (gs.ClassRestriction != template.ClassRestriction) return true;
        if (!StringEqualOrBothBlank(gs.Effect, template.Effect)) return true;
        if (!StringEqualOrBothBlank(gs.RequirementNotes, template.RequirementNotes)) return true;
        if (!gs.BuildingRequirementIds.OrderBy(i => i).SequenceEqual(template.RequiredBuildingIds.OrderBy(i => i))) return true;
        return false;
    }

    private static bool StringEqualOrBothBlank(string? a, string? b)
        => string.Equals(a ?? string.Empty, b ?? string.Empty, StringComparison.Ordinal);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        try
        {
            var gs = await SkillSvc.GetGameSkillsAsync(GameId);
            gameSkills = gs.ToList();
            var all = await SkillSvc.GetAllAsync();
            allTemplates = all.ToList();
            allBuildings = await Api.GetListAsync<BuildingListDto>("/api/buildings");
            buildingNames = allBuildings.ToDictionary(b => b.Id, b => b.Name);
        }
        finally
        {
            loading = false;
        }
    }

    private void OpenChooserPopup()
    {
        isChooserVisible = true;
    }

    private void OpenFromTemplateStep()
    {
        isChooserVisible = false;
        pickedTemplateId = null;
        isTemplatePickerVisible = true;
    }

    private void OpenCustomEdit()
    {
        isChooserVisible = false;
        ResetEditForm();
        editingGameSkillId = null;
        editingTemplateSkillId = null;
        templateInfoLine = "Vlastní (bez šablony)";
        editTitle = "Nová vlastní dovednost";
        isEditVisible = true;
    }

    private void OpenEditFromTemplate()
    {
        if (pickedTemplateId is null) return;
        var tpl = allTemplates.FirstOrDefault(t => t.Id == pickedTemplateId.Value);
        if (tpl is null) return;

        isTemplatePickerVisible = false;
        ResetEditForm();
        editingGameSkillId = null;
        editingTemplateSkillId = tpl.Id;
        templateInfoLine = $"Šablona: {tpl.Name} (Knihovna)";

        editName = tpl.Name;
        editCategory = tpl.Category;
        editClassRestriction = tpl.ClassRestriction ?? PlayerClass.Warrior;
        editEffect = tpl.Effect;
        editRequirementNotes = tpl.RequirementNotes;
        editBuildingIds = tpl.RequiredBuildingIds.ToList();

        xpCost = 0;
        levelRequirement = null;

        editTitle = $"Přidat ze šablony: {tpl.Name}";
        isEditVisible = true;
    }

    private void OpenEditPopup(GameSkillDto gs)
    {
        ResetEditForm();
        editingGameSkillId = gs.Id;
        editingTemplateSkillId = gs.TemplateSkillId;

        if (gs.TemplateSkillId is int tid)
        {
            var tpl = allTemplates.FirstOrDefault(t => t.Id == tid);
            templateInfoLine = tpl is not null
                ? $"Šablona: {tpl.Name} (Knihovna)"
                : "Šablona: (odstraněná)";
        }
        else
        {
            templateInfoLine = "Vlastní (bez šablony)";
        }

        editName = gs.Name;
        editCategory = gs.Category;
        editClassRestriction = gs.ClassRestriction ?? PlayerClass.Warrior;
        editEffect = gs.Effect;
        editRequirementNotes = gs.RequirementNotes;
        editBuildingIds = gs.BuildingRequirementIds.ToList();
        xpCost = gs.XpCost;
        levelRequirement = gs.LevelRequirement;

        editTitle = $"Upravit: {gs.Name}";
        isEditVisible = true;
    }

    private void ResetEditForm()
    {
        editError = null;
        editName = "";
        editCategory = SkillCategory.Class;
        editClassRestriction = PlayerClass.Warrior;
        editEffect = null;
        editRequirementNotes = null;
        editBuildingIds = [];
        newBuildingId = null;
        xpCost = 0;
        levelRequirement = null;
    }

    private void AddBuilding()
    {
        if (newBuildingId is int id && !editBuildingIds.Contains(id))
        {
            editBuildingIds.Add(id);
            newBuildingId = null;
        }
    }

    private void RemoveBuilding(int id)
    {
        editBuildingIds.Remove(id);
    }

    private void OpenDeletePopup(GameSkillDto gs)
    {
        deleteError = null;
        deletingGameSkillId = gs.Id;
        deletingSkillName = gs.Name;
        isDeleteVisible = true;
    }

    private void OnNoLevelRequirementChanged(ChangeEventArgs e)
    {
        var noRequirement = e.Value is bool b && b;
        levelRequirement = noRequirement ? null : 1;
    }

    private async Task SaveAsync()
    {
        editError = null;

        if (string.IsNullOrWhiteSpace(editName))
        {
            editError = "Název je povinný.";
            return;
        }
        if (xpCost < 0)
        {
            editError = "Cena v XP nemůže být záporná.";
            return;
        }
        if (levelRequirement.HasValue && levelRequirement.Value < 0)
        {
            editError = "Požadovaná úroveň nemůže být záporná.";
            return;
        }

        PlayerClass? cr = editCategory == SkillCategory.Class ? editClassRestriction : null;

        isSaving = true;
        try
        {
            if (editingGameSkillId is int gsId)
            {
                await SkillSvc.UpdateGameSkillAsync(GameId, gsId,
                    new UpdateGameSkillRequest(
                        editName,
                        editCategory,
                        cr,
                        editEffect,
                        editRequirementNotes,
                        editBuildingIds,
                        xpCost,
                        levelRequirement));
            }
            else
            {
                await SkillSvc.CreateGameSkillAsync(GameId,
                    new CreateGameSkillRequest(
                        editingTemplateSkillId,
                        editName,
                        editCategory,
                        cr,
                        editEffect,
                        editRequirementNotes,
                        editBuildingIds,
                        xpCost,
                        levelRequirement));
            }
            isEditVisible = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            editError = FormatError(ex);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        deleteError = null;
        isDeleting = true;
        try
        {
            await SkillSvc.RemoveGameSkillAsync(GameId, deletingGameSkillId);
            isDeleteVisible = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            deleteError = FormatError(ex);
        }
        finally
        {
            isDeleting = false;
        }
    }

    private static string FormatError(Exception ex)
    {
        // Best-effort: surface the underlying message. API returns ProblemDetails
        // on 409 when a recipe in this game still requires the skill — the organizer
        // needs to see this so the message is not suppressed.
        return ex.Message;
    }
}
