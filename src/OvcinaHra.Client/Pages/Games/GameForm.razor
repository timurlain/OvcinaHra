@using OvcinaHra.Shared.Domain.Enums

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Název hry</label>
            <input class="form-control" data-testid="game-name"
                   @bind="Model.Name" @bind:event="oninput" />
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Ročník</label>
                <input class="form-control" type="number" data-testid="game-edition"
                       @bind="Model.Edition" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Datum od</label>
                <input class="form-control" type="date" data-testid="game-start-date"
                       @bind="Model.StartDate" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Datum do</label>
                <input class="form-control" type="date" data-testid="game-end-date"
                       @bind="Model.EndDate" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Stav</label>
            <select class="form-select" data-testid="game-status"
                    @bind="Model.Status">
                @foreach (var status in Enum.GetValues<GameStatus>())
                {
                    <option value="@status">@status.GetDisplayName()</option>
                }
            </select>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" data-testid="save-game" @onclick="OnSave">
                Uložit
            </button>
            <button class="btn btn-outline-secondary" @onclick="OnCancel">
                Zrušit
            </button>
            @if (IsEdit)
            {
                <button class="btn btn-outline-danger ms-auto" data-testid="delete-game" @onclick="OnDelete">
                    Smazat
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public GameFormModel Model { get; set; } = default!;
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public bool IsEdit { get; set; }
}
