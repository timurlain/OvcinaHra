@page "/games"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Správa hry</h1>
    <button class="btn btn-primary" data-testid="create-game" @onclick="() => OpenModal(null)">+ Nová hra</button>
</div>

@if (loading)
{
    <p>Načítám...</p>
}
else
{
    <OvcinaGrid Data="@games" KeyFieldName="Id" LayoutKey="grid-layout-games"
                RowClick="@(e => OpenModal((GameListDto)e.Grid.GetDataItem(e.VisibleIndex)))">
        <Columns>
            <DxGridDataColumn FieldName="Name" Caption="Název" />
            <DxGridDataColumn FieldName="Edition" Caption="Ročník" Width="100px" />
            <DxGridDataColumn FieldName="StartDate" Caption="Od" Width="120px" DisplayFormat="d.M.yyyy" />
            <DxGridDataColumn FieldName="EndDate" Caption="Do" Width="120px" DisplayFormat="d.M.yyyy" />
            <DxGridDataColumn FieldName="StatusDisplay" Caption="Stav" Width="140px" />
            <DxGridDataColumn FieldName="ExternalGameId" Caption="Registrace ID" Width="130px" Visible="false" />
        </Columns>
    </OvcinaGrid>
}

@* Detail popup *@
<DxPopup AllowResize="true" @bind-Visible="@isModalVisible" HeaderText="@modalTitle" Width="820px">
    <BodyContentTemplate Context="popupContext">
        <DxFormLayout>
            <DxFormLayoutItem Caption="Název hry" ColSpanMd="12">
                <DxTextBox @bind-Text="@model.Name" data-testid="game-name" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Ročník" ColSpanMd="4">
                <DxSpinEdit @bind-Value="@model.Edition" MinValue="1" data-testid="game-edition" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Od" ColSpanMd="4">
                <DxDateEdit @bind-Date="@startDate" data-testid="game-start-date" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Do" ColSpanMd="4">
                <DxDateEdit @bind-Date="@endDate" data-testid="game-end-date" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Stav" ColSpanMd="12">
                <DxComboBox Data="@statusValues" @bind-Value="@model.Status"
                            TextFieldName="Display" ValueFieldName="Value" data-testid="game-status" />
            </DxFormLayoutItem>
        </DxFormLayout>

        @* Bounding box picker — only while editing. Create flow doesn't need it
           because the game record must exist before a bbox is meaningful; the
           user can set it on first edit. *@
        @if (editingId.HasValue)
        {
            <DxFormLayout CssClass="mt-3">
                <DxFormLayoutGroup Caption="Oblast hry na mapě" ColSpanMd="12">
                    <DxFormLayoutItem ColSpanMd="12">
                        <BoundingBoxPicker Value="@bboxValue" ValueChanged="OnBboxChanged" />
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>
        }

        @if (error is not null)
        {
            <div class="alert alert-danger mt-2">@error</div>
        }

        <div class="d-flex gap-2 mt-3">
            @* Dovednosti button removed per #146 — it didn't belong in the
               Game edit popup; /games/{id}/skills is reachable via its own
               nav surfaces. *@
            <div style="flex: 1"></div>
            <button class="btn btn-secondary" @onclick="CloseModal" disabled="@isSaving">Zrušit</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving" data-testid="save-game">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Uložit
            </button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@* Create confirmation *@
<DxPopup @bind-Visible="@isCreateConfirmVisible" HeaderText="Vytvořit novou hru?" Width="400px">
    <BodyContentTemplate Context="popupContext">
        <p>Opravdu chcete vytvořit nový ročník hry <strong>@model.Name</strong>?</p>
        <p class="text-muted small">Tato akce vytvoří nový záznam v databázi.</p>
        <div class="d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isCreateConfirmVisible = false">Zrušit</button>
            <button class="btn btn-primary" @onclick="ConfirmSaveAsync">Vytvořit</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    private List<GameListDto> games = [];
    private bool loading = true;

    // Modal state
    private bool isModalVisible;
    private bool isCreateConfirmVisible;
    private bool isSaving;
    private string modalTitle = "";
    private string? error;
    private int? editingId;
    private GameFormModel model = new();
    private BoundingBoxPicker.BboxValue bboxValue = BoundingBoxPicker.BboxValue.Empty;

    // DateEdit works with DateTime, not DateOnly
    private DateTime startDate
    {
        get => model.StartDate.ToDateTime(TimeOnly.MinValue);
        set => model.StartDate = DateOnly.FromDateTime(value);
    }
    private DateTime endDate
    {
        get => model.EndDate.ToDateTime(TimeOnly.MinValue);
        set => model.EndDate = DateOnly.FromDateTime(value);
    }

    // Status combobox items
    private static readonly List<StatusItem> statusValues = Enum.GetValues<GameStatus>()
        .Select(s => new StatusItem(s, s.GetDisplayName()))
        .ToList();

    record StatusItem(GameStatus Value, string Display);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loading = true;
        games = await Api.GetListAsync<GameListDto>("/api/games");
        loading = false;
    }

    private async Task OpenModal(GameListDto? game)
    {
        error = null;
        if (game is null)
        {
            editingId = null;
            model = new GameFormModel();
            bboxValue = BoundingBoxPicker.BboxValue.Empty;
            modalTitle = "Nová hra";
        }
        else
        {
            editingId = game.Id;
            // Fetch full detail to pull bounding-box fields (list DTO omits them).
            var detail = await Api.GetAsync<GameDetailDto>($"/api/games/{game.Id}");
            if (detail is null)
            {
                error = $"Hru se nepodařilo načíst (ID {game.Id}).";
                return;
            }
            model = GameFormModel.FromDetail(detail);
            bboxValue = new BoundingBoxPicker.BboxValue(
                detail.BoundingBoxSwLat, detail.BoundingBoxSwLng,
                detail.BoundingBoxNeLat, detail.BoundingBoxNeLng);
            modalTitle = $"Upravit: {game.Name}";
        }
        isModalVisible = true;
    }

    private void OnBboxChanged(BoundingBoxPicker.BboxValue next)
    {
        bboxValue = next;
        model.BoundingBoxSwLat = next.SwLat;
        model.BoundingBoxSwLng = next.SwLng;
        model.BoundingBoxNeLat = next.NeLat;
        model.BoundingBoxNeLng = next.NeLng;
    }

    private void CloseModal() => isModalVisible = false;

    private async Task SaveAsync()
    {
        error = null;
        if (editingId.HasValue)
        {
            // Edit — save directly
            isSaving = true;
            try
            {
                await Api.PutAsync($"/api/games/{editingId}", model.ToUpdateDto());
                isModalVisible = false;
                await LoadDataAsync();
            }
            catch (Exception ex) { error = ex.Message; }
            finally { isSaving = false; }
        }
        else
        {
            // Create — show confirmation first
            isCreateConfirmVisible = true;
        }
    }

    private async Task ConfirmSaveAsync()
    {
        isCreateConfirmVisible = false;
        isSaving = true;
        try
        {
            await Api.PostAsync<CreateGameDto, GameDetailDto>("/api/games", model.ToCreateDto());
            isModalVisible = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isSaving = false; }
    }
}
