@page "/auth-callback"
@attribute [AllowAnonymous]
@inject IJSRuntime JS
@inject HttpClient Http
@inject JwtAuthStateProvider AuthProvider
@inject TokenRefreshService RefreshService
@inject NavigationManager Nav

<div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
    <div class="text-center">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <p>@statusMessage</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "code")] private string? Code { get; set; }
    [SupplyParameterFromQuery(Name = "state")] private string? State { get; set; }
    [SupplyParameterFromQuery(Name = "error")] private string? Error { get; set; }

    private string statusMessage = "Přihlašování...";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            await LogToServer($"AuthCallback started: code={!string.IsNullOrEmpty(Code)}, state={!string.IsNullOrEmpty(State)}, error={Error}");

            if (!string.IsNullOrEmpty(Error))
            {
                Nav.NavigateTo($"/login?error={Error}");
                return;
            }

            if (!string.IsNullOrEmpty(Code))
            {
                var storedState = await JS.InvokeAsync<string?>("localStorage.getItem", "oidc_state");
                var codeVerifier = await JS.InvokeAsync<string?>("localStorage.getItem", "oidc_verifier");
                await JS.InvokeVoidAsync("localStorage.removeItem", "oidc_state");
                await JS.InvokeVoidAsync("localStorage.removeItem", "oidc_verifier");

                await LogToServer($"State check: stored={storedState?[..Math.Min(8, storedState?.Length ?? 0)]}..., received={State?[..Math.Min(8, State?.Length ?? 0)]}..., match={storedState == State}");

                if (string.IsNullOrEmpty(storedState) || storedState != State)
                {
                    Nav.NavigateTo("/login?error=invalid_state");
                    return;
                }

                await ExchangeCodeAsync(codeVerifier);
                return;
            }

            // Legacy: token in URL fragment
            var token = await JS.InvokeAsync<string?>("eval",
                "new URLSearchParams(window.location.hash.substring(1)).get('token')");

            if (!string.IsNullOrEmpty(token))
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "auth_token", token);
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                await LogToServer("No code, no error, no token fragment — redirecting to login");
                Nav.NavigateTo("/login?error=no_token");
            }
        }
        catch (Exception ex)
        {
            await LogToServer($"AuthCallback exception: {ex.Message}");
            Nav.NavigateTo($"/login?error=auth_failed");
        }
    }

    private async Task ExchangeCodeAsync(string? codeVerifier)
    {
        try
        {
            var redirectUri = $"{Nav.BaseUri}auth-callback";
            await LogToServer($"Exchanging code: redirectUri={redirectUri}, hasVerifier={!string.IsNullOrEmpty(codeVerifier)}");

            var response = await Http.PostAsJsonAsync("/api/auth/oidc-exchange",
                new { Code, RedirectUri = redirectUri, CodeVerifier = codeVerifier });

            await LogToServer($"Exchange response: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                await LogToServer($"Exchange body: {body[..Math.Min(200, body.Length)]}");

                var token = System.Text.Json.JsonSerializer.Deserialize<OvcinaHra.Client.Auth.TokenResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                await LogToServer($"Token parsed: token={token?.Token?[..Math.Min(20, token?.Token?.Length ?? 0)]}..., expires={token?.ExpiresInSeconds}");

                if (token?.Token is not null)
                {
                    await AuthProvider.SetTokenAsync(token.Token);
                    await LogToServer("Token stored, navigating to /");
                    RefreshService.ScheduleRefresh(token.ExpiresInSeconds);
                    Nav.NavigateTo("/");
                    return;
                }
            }

            var errorBody = await response.Content.ReadAsStringAsync();
            await LogToServer($"Exchange failed: {response.StatusCode} body={errorBody}");
            Nav.NavigateTo("/login?error=auth_failed");
        }
        catch (Exception ex)
        {
            await LogToServer($"Exchange exception: {ex.GetType().Name}: {ex.Message}");
            Nav.NavigateTo("/login?error=auth_failed");
        }
    }

    private async Task LogToServer(string message)
    {
        try
        {
            statusMessage = message;
            StateHasChanged();
            await Http.PostAsJsonAsync("/api/admin/logs/client", new { level = "info", message, stack = (string?)null });
        }
        catch { /* ignore logging failures */ }
    }
}
