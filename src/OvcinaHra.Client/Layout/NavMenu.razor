@using System.Reflection

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <i class="bi bi-feather me-1"></i> OvčinaHra
        </a>
        <button title="Navigační menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable">
    <nav class="nav flex-column" @onclick="ToggleNavMenu">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill"></i> Přehled
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="mapa">
                <i class="bi bi-map-fill"></i> Mapa
            </NavLink>
        </div>

        <div class="oh-nav-section-label">Správa hry</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="hry">
                <i class="bi bi-calendar-event-fill"></i> Seznam Ovčin
            </NavLink>
        </div>

        <div class="oh-nav-section-label">Svět</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="lokace">
                <i class="bi bi-geo-alt-fill"></i> Lokace
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="prisery">
                <i class="bi bi-bug-fill"></i> Příšery
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="questy">
                <i class="bi bi-journal-text"></i> Questy
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="predmety">
                <i class="bi bi-gem"></i> Předměty
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="poklady">
                <i class="bi bi-safe-fill"></i> Poklady
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="budovy">
                <i class="bi bi-houses-fill"></i> Budovy
            </NavLink>
        </div>

        <div class="oh-nav-section-label">Nástroje</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tagy">
                <i class="bi bi-tags-fill"></i> Tagy
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="hledani">
                <i class="bi bi-search"></i> Hledání
            </NavLink>
        </div>
    </nav>

    <div class="nav-footer">
        <button class="collapse-toggle" title="Sbalit menu" @onclick="OnToggle" @onclick:stopPropagation="true">
            <i class="bi @(Collapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
        </button>
        @if (!Collapsed)
        {
            <span>© 2026 Ovčina v@(AppVersion)</span>
        }
    </div>
</div>

@code {
    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public EventCallback OnToggle { get; set; }

    private static string AppVersion =>
        typeof(NavMenu).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()
            ?.InformationalVersion.Split('+')[0] ?? "dev";

    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
}
