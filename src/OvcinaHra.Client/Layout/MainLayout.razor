@inherits LayoutComponentBase

<VersionDriftBanner />

<div class="page @(sidebarCollapsed ? "sidebar-collapsed" : "")">
    <div class="sidebar">
        <NavMenu Collapsed="sidebarCollapsed" OnToggle="ToggleSidebar" />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center">
            <AuthorizeView>
                <Authorized>
                    <GameSelector />
                    <div style="flex: 1"></div>
                    <span class="me-3">@context.User.Identity?.Name</span>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">Odhlásit</button>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [Inject] private JwtAuthStateProvider AuthProvider { get; set; } = default!;

    private bool sidebarCollapsed;
    private void ToggleSidebar() => sidebarCollapsed = !sidebarCollapsed;

    private async Task Logout()
    {
        await AuthProvider.ClearTokenAsync();
    }
}
