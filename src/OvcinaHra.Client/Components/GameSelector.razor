@inject GameContextService GameContext

<div class="d-inline-flex align-items-center">
    @if (GameContext.GameName is not null)
    {
        <i class="bi bi-shield-fill me-1 text-moss"></i>
        <span class="fw-semibold" style="font-family: var(--oh-font-heading);">@GameContext.GameName</span>
    }
    else
    {
        <span class="text-muted small">Žádná aktivní hra</span>
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await GameContext.InitializeAsync();
    }
}
