@using OvcinaHra.Shared.Domain.Enums
@using OvcinaHra.Shared.Extensions

@* Small coloured chip for the output item's ItemType-derived recipe category. *@

<span class="oh-rec-cat oh-rec-cat-@CssKey" title="@Category.GetDisplayName()">
    <i class="bi @Icon"></i>
    <span>@Category.GetDisplayName()</span>
</span>

@code {
    [Parameter, EditorRequired] public ItemType Category { get; set; }

    private string CssKey => Category switch
    {
        ItemType.Potion => "lektvar",
        ItemType.Artifact or ItemType.MinorArtifact or ItemType.Jewelry or ItemType.Scroll => "artefakt",
        _ => "ostatni"
    };

    private string Icon => Category switch
    {
        ItemType.Potion => "bi-droplet-half",
        ItemType.Artifact or ItemType.MinorArtifact or ItemType.Jewelry or ItemType.Scroll => "bi-gem",
        ItemType.Money => "bi-coin",
        ItemType.Resource or ItemType.Ingredient or ItemType.Commodity => "bi-box-seam",
        _ => "bi-tag"
    };
}
