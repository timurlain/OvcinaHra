@using OvcinaHra.Shared.Domain.Enums
@using OvcinaHra.Shared.Dtos
@using OvcinaHra.Client.Pages.Locations
@inject ApiClient Api

<DxPopup AllowResize="true" @bind-Visible="@isVisible" HeaderText="@modalTitle" Width="900px" MinHeight="700px"
         CloseOnOutsideClick="false" ShowCloseButton="true">
    <BodyContentTemplate Context="popupContext">
        <DxTabs @bind-ActiveTabIndex="@activeTab" CssClass="location-tabs">
            <DxTab Text="Karta" />
            <DxTab Text="Upravit" />
            <DxTab Text="Lore" />
        </DxTabs>

        @* ── Tab 0: Card view (read-only presentation) ── *@
        @if (activeTab == 0)
        {
            <div class="location-card">
                <div class="location-card-body">
                    <div class="location-card-text">
                        <h2 class="location-card-title">@model.Name</h2>
                        @if (!string.IsNullOrWhiteSpace(model.Region))
                        {
                            <div class="location-card-region">@model.Region — @model.LocationKind.GetDisplayName()</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(model.Description))
                        {
                            <p class="location-card-description">@model.Description</p>
                        }
                    </div>
                    @if (imageUrl is not null)
                    {
                        <div class="location-card-image">
                            <img src="@imageUrl" alt="@model.Name" />
                        </div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(model.Details))
                {
                    <div class="location-card-details">
                        <p>@model.Details</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(model.GamePotential))
                {
                    <div class="location-card-potential">
                        <strong>Herní potenciál:</strong> @model.GamePotential
                    </div>
                }

                @* Variant links on card *@
                @if (parentName is not null)
                {
                    <div class="location-card-variants">
                        <small class="text-muted">Varianta lokace</small>
                        <a href="#" @onclick="() => OnVariantNavigate.InvokeAsync(parentId!.Value)" @onclick:preventDefault class="d-block fw-bold">
                            ← @parentName
                        </a>
                    </div>
                }
                @if (variants.Count > 0)
                {
                    <div class="location-card-variants">
                        <small class="text-muted">Varianty (@variants.Count)</small>
                        @foreach (var v in variants)
                        {
                            <a href="#" @onclick="() => OnVariantNavigate.InvokeAsync(v.Id)" @onclick:preventDefault class="d-block">
                                → @v.Name <span class="text-muted">(@v.LocationKind.GetDisplayName())</span>
                            </a>
                        }
                    </div>
                }

                <div class="location-card-id">@(editingId?.ToString("D2") ?? "?")</div>
            </div>
        }

        @* ── Tab 1: Edit form ── *@
        @if (activeTab == 1)
        {
            <DxFormLayout CssClass="mt-2">
                <DxFormLayoutItem Caption="Název" ColSpanMd="8">
                    <DxTextBox @bind-Text="@model.Name" data-testid="location-name" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Typ" ColSpanMd="4">
                    <DxComboBox Data="@kindValues" @bind-Value="@model.LocationKind"
                                TextFieldName="Display" ValueFieldName="Value" data-testid="location-kind" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Oblast" ColSpanMd="6">
                    <DxTextBox @bind-Text="@model.Region" data-testid="location-region" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="GPS" ColSpanMd="6">
                    @if (model.Latitude.HasValue && model.Longitude.HasValue)
                    {
                        <div class="text-muted small mt-1">@($"{model.Latitude.Value:F7}, {model.Longitude.Value:F7}") — upravit na mapě</div>
                    }
                    else
                    {
                        <div class="text-muted small mt-1"><span class="badge bg-warning text-dark">Nepřiřazeno</span> — nastavit na mapě nebo přes kontext. menu</div>
                    }
                </DxFormLayoutItem>
                @if (editingId.HasValue)
                {
                    <DxFormLayoutItem Caption="Obrázek" ColSpanMd="12">
                        <ImagePicker EntityType="locations" EntityId="editingId.Value" Alt="Ilustrace lokace" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Foto umístění" ColSpanMd="12">
                        <ImagePicker EntityType="locations" EntityId="editingId.Value" Field="placement" Alt="Foto umístění" />
                    </DxFormLayoutItem>
                }
                <DxFormLayoutItem Caption="Info pro CP (NPC)" ColSpanMd="12">
                    <DxMemo @bind-Text="@model.NpcInfo" Rows="4" data-testid="location-npc" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Co nachystat na lokaci" ColSpanMd="12">
                    <DxMemo @bind-Text="@model.SetupNotes" Rows="3" data-testid="location-setup" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Rodič" ColSpanMd="12">
                    <DxComboBox Data="@parentCandidates" @bind-Value="@model.ParentLocationId"
                                TextFieldName="Name" ValueFieldName="Id"
                                NullText="(žádný — tato lokace je kořenová)"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                SearchMode="ListSearchMode.AutoSearch" />
                </DxFormLayoutItem>
            </DxFormLayout>

            @if (error is not null) { <div class="alert alert-danger mt-2">@error</div> }

            <div class="d-flex gap-2 mt-3">
                @if (editingId.HasValue)
                {
                    <button class="btn btn-outline-danger" @onclick="() => isDeleteVisible = true" disabled="@isSaving" data-testid="delete-location">Smazat</button>
                }
                <div style="flex: 1"></div>
                <button class="btn btn-secondary" @onclick="Close" disabled="@isSaving">Zrušit</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving" data-testid="save-location">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Uložit
                </button>
            </div>
        }

        @* ── Tab 2: Lore editing ── *@
        @if (activeTab == 2)
        {
            <div class="mt-2 mb-3">
                <button class="btn btn-sm @(isLoreEditable ? "btn-warning" : "btn-outline-secondary")"
                        @onclick="() => isLoreEditable = !isLoreEditable">
                    @(isLoreEditable ? "Zamknout texty" : "Upravit texty")
                </button>
            </div>
            <DxFormLayout>
                <DxFormLayoutItem Caption="Popis (fantasy)" ColSpanMd="12">
                    <DxMemo @bind-Text="@model.Description" Rows="6" ReadOnly="@(!isLoreEditable)" data-testid="location-description" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Detaily" ColSpanMd="12">
                    <DxMemo @bind-Text="@model.Details" Rows="8" ReadOnly="@(!isLoreEditable)" data-testid="location-details" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Herní potenciál" ColSpanMd="12">
                    <DxMemo @bind-Text="@model.GamePotential" Rows="4" data-testid="location-gamepotential" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Prompt (Midjourney)" ColSpanMd="12">
                    <DxMemo @bind-Text="@model.Prompt" Rows="3" data-testid="location-prompt" />
                </DxFormLayoutItem>
            </DxFormLayout>

            @if (error is not null) { <div class="alert alert-danger mt-2">@error</div> }

            <div class="d-flex gap-2 mt-3">
                <div style="flex: 1"></div>
                <button class="btn btn-secondary" @onclick="Close">Zrušit</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving" data-testid="save-location">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Uložit
                </button>
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="@isDeleteVisible" HeaderText="Potvrdit smazání" Width="400px">
    <BodyContentTemplate Context="popupContext">
        <p>Opravdu chcete smazat lokaci <strong>@model.Name</strong>?</p>
        <div class="d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary" @onclick="() => isDeleteVisible = false">Zrušit</button>
            <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Smazat</button>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback<int> OnVariantNavigate { get; set; }
    /// <summary>Provides all locations for resolving parent names.</summary>
    [Parameter] public List<LocationListDto> AllLocations { get; set; } = [];
    /// <summary>When set (game mode), newly created locations are auto-assigned to this game.</summary>
    [Parameter] public int? GameId { get; set; }

    private bool isVisible, isDeleteVisible, isSaving;
    private bool isLoreEditable;
    private int activeTab;
    private string modalTitle = "";
    private string? error;
    private int? editingId;
    private string? imageUrl;
    private LocationFormModel model = new();
    private int? parentId;
    private string? parentName;
    private List<LocationVariantDto> variants = [];
    private List<LocationListDto> parentCandidates = [];

    private static readonly List<KindItem> kindValues = Enum.GetValues<LocationKind>()
        .Select(k => new KindItem(k, k.GetDisplayName())).ToList();
    record KindItem(LocationKind Value, string Display);

    /// <summary>Open for editing an existing location.</summary>
    public async Task OpenAsync(int locationId)
    {
        error = null;
        isLoreEditable = false;
        activeTab = 0;
        var detail = await Api.GetAsync<LocationDetailDto>($"/api/locations/{locationId}");
        if (detail is null) return;

        editingId = locationId;
        model = LocationFormModel.FromDetail(detail);
        modalTitle = detail.Name;
        // Load illustration for card view
        try
        {
            var urls = await Api.GetAsync<ImageUrlsDto>($"/api/images/locations/{locationId}");
            imageUrl = urls?.ImageUrl;
        }
        catch { imageUrl = null; }
        variants = detail.Variants;
        parentId = detail.ParentLocationId;
        parentName = parentId.HasValue
            ? AllLocations.FirstOrDefault(l => l.Id == parentId.Value)?.Name ?? $"Lokace #{parentId}"
            : null;
        parentCandidates = AllLocations
            .Where(l => l.Id != locationId && l.ParentLocationId != locationId)
            .OrderBy(l => l.Name)
            .ToList();
        isVisible = true;
    }

    /// <summary>Open for creating a new location at given coordinates.</summary>
    public void OpenNew(decimal latitude = 49.4532m, decimal longitude = 18.0203m)
    {
        error = null;
        isLoreEditable = false;
        activeTab = 0;
        editingId = null;
        imageUrl = null;
        model = new LocationFormModel { Latitude = latitude, Longitude = longitude };
        modalTitle = "Nová lokace";
        variants = [];
        parentId = null;
        parentName = null;
        parentCandidates = AllLocations.OrderBy(l => l.Name).ToList();
        isVisible = true;
    }

    public void Close() => isVisible = false;

    private async Task SaveAsync()
    {
        error = null; isSaving = true;
        try
        {
            if (editingId.HasValue)
                await Api.PutAsync($"/api/locations/{editingId}", model.ToUpdateDto());
            else
            {
                var created = await Api.PostAsync<CreateLocationDto, LocationDetailDto>("/api/locations", model.ToCreateDto());
                if (GameId is not null && created is not null)
                    await Api.PostAsync<GameLocationDto, object>("/api/locations/by-game", new GameLocationDto(GameId.Value, created.Id));
            }

            isVisible = false;
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        isSaving = true;
        try
        {
            await Api.DeleteAsync($"/api/locations/{editingId}");
            isDeleteVisible = false;
            isVisible = false;
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isSaving = false; }
    }
}
