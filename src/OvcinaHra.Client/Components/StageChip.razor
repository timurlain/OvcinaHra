@using OvcinaHra.Shared.Domain.Enums
@using OvcinaHra.Shared.Extensions

<span class="oh-stage-chip @CssClass(Difficulty)">@(Text ?? Difficulty.GetDisplayName())</span>

@code {
    [Parameter, EditorRequired] public GameTimePhase Difficulty { get; set; }
    [Parameter] public string? Text { get; set; }

    private static string CssClass(GameTimePhase d) => d switch
    {
        GameTimePhase.Start => "oh-stage-chip-start",
        GameTimePhase.Early => "oh-stage-chip-early",
        GameTimePhase.Midgame => "oh-stage-chip-mid",
        GameTimePhase.Lategame => "oh-stage-chip-late",
        GameTimePhase.EndGame => "oh-stage-chip-endgame",
        _ => throw new ArgumentOutOfRangeException(nameof(d), d, null)
    };
}
